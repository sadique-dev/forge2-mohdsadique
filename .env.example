# ENV example — placeholders only. Never commit your real .env
APP_NAME=PulseDesk
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pulsedesk
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

SANCTUM_STATEFUL_DOMAINS=localhost:5173

# EastRouter — never commit the real key
EASTROUTER_API_KEY=sk-er_REPLACE_WITH_REAL_KEY

# Slack bot credentials — never commit real tokens
SLACK_BOT_TOKEN=xoxb-REPLACE_WITH_REAL_TOKEN
SLACK_APP_TOKEN=xapp-REPLACE_WITH_REAL_TOKEN

VITE_API_BASE_URL=http://localhost:8000/api/v1
